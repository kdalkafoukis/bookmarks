{
  "manifest_version": 3,
  "name": "Bookmarks Search",
  "version": "0.1.0",
  "description": "Full-text search your bookmarks via a local SQLite FTS5 index.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "host_permissions": ["http://127.0.0.1:7777/*"]
}
